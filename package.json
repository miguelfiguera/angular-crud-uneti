{
  "name": "cine-uneti",
  "version": "1.0.0",
  "private": true,
  "description": "Sistema CRUD de películas con Angular, Node.js y MongoDB",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "install:all": "yarn install",
    "postinstall": "node scripts/run-seed.js",
    "start": "concurrently -n api,web -c blue,green \"yarn workspace backend start\" \"yarn workspace frontend start\"",
    "start:backend": "yarn workspace backend start",
    "start:frontend": "yarn workspace frontend start",
    "seed": "node scripts/run-seed.js",
    "mongo-test": "bash scripts/mongo-test.sh"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "playwright": "1.51.0"
  },
  "engines": {
    "node": ">=18"
  }
}
